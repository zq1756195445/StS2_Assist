{
  "name": "spire-guide",
  "version": "0.2.0",
  "private": true,
  "description": "Rust + Tauri MVP assistant overlay for Slay the Spire 2",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "start": "tauri dev",
    "hud:dev": "powershell -ExecutionPolicy Bypass -File .\\tools\\launch_hud_dev.ps1",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "extract:sts2-localization": "node tools/extract_sts2_localization.mjs",
    "replay:probe": "python3 tools/replay_probe.py",
    "hook:build": "dotnet build tools/Sts2EventHook",
    "game:launch-log": "powershell -ExecutionPolicy Bypass -File .\\tools\\launch_sts2_with_log_bridge.ps1",
    "test": "cargo test --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.4.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.4.0",
    "vite": "^7.1.0"
  }
}
