{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SpireGuide",
  "version": "0.2.0",
  "identifier": "com.cheemtain.spireguide",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "SpireGuide",
        "width": 520,
        "height": 860,
        "decorations": true,
        "transparent": true,
        "alwaysOnTop": true,
        "resizable": true,
        "skipTaskbar": false,
        "visible": true,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
